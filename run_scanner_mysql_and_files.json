{
  "scan": {
    "input_paths": [
      "test_data"
    ],
    "recursive": true,
    "include_extensions": [
      ".txt",
      ".csv",
      ".json",
      ".log",
      ".md",
      ".xml",
      ".yaml",
      ".yml",
      ".pdf",
      ".docx",
      ".png",
      ".jpg",
      ".jpeg"
    ],
    "exclude_dirs": [
      ".git",
      ".idea",
      ".venv",
      "venv",
      "__pycache__",
      "node_modules",
      "dist",
      "build"
    ],
    "exclude_file_globs": [
      "*.pyc",
      "*.pyo",
      "*.DS_Store"
    ],
    "max_file_size_mb": 20,
    "read_binary_files_as_text": false,
    "pdf_max_pages": 50,
    "ocr_images": false
  },
  "presidio": {
    "language": "en",
    "supported_languages": [
      "en"
    ],
    "nlp_engine_name": "spacy",
    "model_name": "en_core_web_lg",
    "entities": [
      "IN_AADHAAR",
      "IN_PAN",
      "IN_IFSC",
      "IN_UPI_ID",
      "IN_PASSPORT",
      "IN_BANK_ACCOUNT",
      "EMAIL_ADDRESS",
      "PHONE_NUMBER",
      "PERSON",
      "LOCATION",
      "IN_ADDRESS",
      "CREDIT_CARD",
      "IBAN_CODE",
      "IP_ADDRESS"
    ],
    "score_threshold": 0.35,
    "entity_score_thresholds": {
      "PERSON": 0.6,
      "LOCATION": 0.55,
      "PHONE_NUMBER": 0.55,
      "EMAIL_ADDRESS": 0.6,
      "IN_BANK_ACCOUNT": 0.45
    },
    "return_decision_process": false,
    "allow_list": [],
    "allow_list_match": "exact",
    "context_words": [
      "customer",
      "identity",
      "bank",
      "payment",
      "contact"
    ],
    "spacy_max_length": 3000000,
    "chunk_size_chars": 200000,
    "chunk_overlap_chars": 500,
    "context_enhancer": {
      "enabled": true,
      "context_similarity_factor": 0.35,
      "min_score_with_context_similarity": 0.45,
      "context_prefix_count": 8,
      "context_suffix_count": 2
    }
  },
  "custom_recognizers": {
    "enable_indian_identifiers": true,
    "aadhaar_checksum_validation": true,
    "upi_generic_pattern": false,
    "upi_handle_domains": [
      "upi",
      "ybl",
      "ibl",
      "axl",
      "paytm",
      "okhdfcbank",
      "okicici",
      "oksbi",
      "okaxis"
    ]
  },
  "rule_engine": {
    "enabled": true,
    "region": "india",
    "environment_variable": "DPDP_RULES_ENV",
    "default_environment": "default",
    "environment": "default",
    "base_rules_file": "config/pii_rules/india/base_rules.json",
    "environment_rules": {
      "default": "config/pii_rules/india/default_rules.json",
      "dev": "config/pii_rules/india/dev_rules.json",
      "qa": "config/pii_rules/india/qa_rules.json",
      "prod": "config/pii_rules/india/prod_rules.json"
    }
  },
  "sources": {
    "enabled_sources": [
      "filesystem",
      "database"
    ],
    "filesystem": {
      "enabled": true,
      "locations": [
        {
          "name": "local_test_data",
          "enabled": true,
          "provider": "local",
          "input_paths": [
            "test_data"
          ],
          "recursive": true
        }
      ]
    },
    "database": {
      "enabled": true,
      "scanner": "piicatcher",
      "piicatcher": {
        "enabled": true,
        "catalog_path": ":memory:",
        "app_dir": ".piicatcher",
        "secret": "",
        "source_type": "",
        "source_name": "",
        "source_kwargs": {},
        "add_source_function_candidates": []
      },
      "connections": [
        {
          "name": "mysql_local_sample",
          "enabled": true,
          "type": "mysql",
          "url": "mysql://root:@127.0.0.1:3306/dpdp_scanner_sample",
          "database": "dpdp_scanner_sample",
          "include_tables": [
            "customers",
            "payments",
            "employee_profiles"
          ],
          "auth": {
            "username": "root",
            "password": "",
            "password_env": "DPDP_MYSQL_PASSWORD",
            "keytab_file": "",
            "kerberos_principal": "",
            "kerberos_realm": ""
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "mysql",
            "source_name": "mysql_local_sample",
            "source_kwargs": {
              "uri": "127.0.0.1",
              "port": 3306,
              "username": "root",
              "password": "",
              "database": "dpdp_scanner_sample"
            }
          }
        },
        {
          "name": "postgres_remote",
          "enabled": false,
          "type": "postgresql",
          "url": "postgresql://readonly_user:password@db-host.example.com:5432/customer_db",
          "database": "customer_db",
          "include_tables": [
            "customers",
            "orders"
          ],
          "auth": {
            "username": "readonly_user",
            "password": "",
            "password_env": "DPDP_POSTGRES_PASSWORD",
            "keytab_file": "/etc/security/keytabs/dpdp_scanner.keytab",
            "kerberos_principal": "svc-dpdp@EXAMPLE.COM",
            "kerberos_realm": "EXAMPLE.COM"
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "postgresql",
            "source_name": "postgres_remote"
          }
        },
        {
          "name": "mssql_remote",
          "enabled": false,
          "type": "mssql",
          "url": "mssql://scanner_user:password@sqlserver.example.com:1433/customer_db",
          "database": "customer_db",
          "include_tables": [
            "customer_master"
          ],
          "auth": {
            "username": "scanner_user",
            "password": "",
            "password_env": "DPDP_MSSQL_PASSWORD",
            "keytab_file": "",
            "kerberos_principal": ""
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "mssql",
            "source_name": "mssql_remote",
            "add_source_function_candidates": [
              "add_mssql_source",
              "add_sqlserver_source"
            ]
          }
        },
        {
          "name": "oracle_remote",
          "enabled": false,
          "type": "oracle",
          "url": "oracle://scanner_user:password@oracle-host.example.com:1521/ORCLPDB1",
          "database": "ORCLPDB1",
          "include_tables": [
            "CUSTOMER_PROFILE"
          ],
          "auth": {
            "username": "scanner_user",
            "password": "",
            "password_env": "DPDP_ORACLE_PASSWORD",
            "keytab_file": "/etc/security/keytabs/oracle_scanner.keytab",
            "kerberos_principal": "svc-oracle@EXAMPLE.COM"
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "oracle",
            "source_name": "oracle_remote",
            "add_source_function_candidates": [
              "add_oracle_source"
            ]
          }
        },
        {
          "name": "rds_mysql_prod",
          "enabled": false,
          "type": "mysql",
          "url": "mysql://scanner_user:password@rds-mysql-prod.abcdef.us-east-1.rds.amazonaws.com:3306/customer_db",
          "database": "customer_db",
          "include_tables": [
            "customer_profile",
            "payment_cards"
          ],
          "auth": {
            "username": "scanner_user",
            "password": "",
            "password_env": "DPDP_RDS_MYSQL_PASSWORD"
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "mysql",
            "source_name": "rds_mysql_prod"
          }
        },
        {
          "name": "dynamodb_customer_records",
          "enabled": false,
          "type": "dynamodb",
          "url": "dynamodb://dynamodb.us-east-1.amazonaws.com/customer_records",
          "table_name": "customer_records",
          "auth": {
            "aws_access_key_id_env": "AWS_ACCESS_KEY_ID",
            "aws_secret_access_key_env": "AWS_SECRET_ACCESS_KEY",
            "aws_session_token_env": "AWS_SESSION_TOKEN",
            "region_env": "AWS_REGION"
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "dynamodb",
            "source_name": "dynamodb_customer_records",
            "add_source_function_candidates": [
              "add_dynamodb_source"
            ],
            "source_kwargs": {
              "region": "us-east-1",
              "table_name": "customer_records"
            }
          }
        }
      ]
    }
  },
  "output": {
    "path": "output/output.json",
    "pretty": true,
    "include_text_snippet": true,
    "snippet_context_chars": 24,
    "include_analysis_explanation": false,
    "include_file_hash": true,
    "include_source_metadata": true,
    "mask_file_paths": false,
    "file_path_mask_mode": "full",
    "file_path_base_dir": "",
    "file_path_hash_salt": ""
  }
}
