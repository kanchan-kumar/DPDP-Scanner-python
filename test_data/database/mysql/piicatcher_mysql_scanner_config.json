{
  "rule_engine": {
    "enabled": false
  },
  "sources": {
    "enabled_sources": [
      "database"
    ],
    "filesystem": {
      "enabled": false,
      "locations": []
    },
    "database": {
      "enabled": true,
      "scanner": "piicatcher",
      "piicatcher": {
        "enabled": true,
        "catalog_path": ":memory:",
