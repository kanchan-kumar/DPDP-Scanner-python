          "database": "dpdp_scanner_sample",
          "include_tables": [
            "customers",
            "payments",
            "employee_profiles"
          ],
          "auth": {
            "username": "root",
            "password": "",
            "password_env": "DPDP_DB_PASSWORD",
            "keytab_file": "",
            "kerberos_principal": ""
          },
          "piicatcher": {
            "enabled": true,
            "source_type": "mysql",
            "source_name": "local_mysql_sample",
            "source_kwargs": {
              "uri": "127.0.0.1",
              "port": 3306,
              "username": "root",
              "password": "",
              "database": "dpdp_scanner_sample"
            }
          }
        }
      ]
    }
  },
  "scan": {
    "input_paths": []
  },
  "output": {
    "path": "output/output.json",
