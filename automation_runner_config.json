{
  "target_environment": "auto",
  "allow_cross_target": false,
  "python": {
    "version": "3.10",
    "executable": "",
    "install_if_missing": true
  },
  "environment": {
    "venv_dir": ".venv",
    "clear": false,
    "preserve_existing_venv_when_offline": true
  },
  "dependencies": {
    "enabled": true,
    "requirements_file": "requirements.txt",
    "use_no_build_isolation": true,
    "allow_offline_reuse_existing": true,
    "offline_required_modules": [
      "presidio_analyzer",
      "presidio_anonymizer",
      "spacy",
      "PyPDF2",
      "docx",
      "pymysql",
      "psycopg2",
      "piicatcher",
      "dbcat"
    ],
    "install_poetry_core": true,
    "apply_compatibility_overrides": true,
    "run_pip_check": true,
    "pip_check_strict": false,
    "compatibility_overrides": [
      "presidio-analyzer>=2.2.0,<3",
      "presidio-anonymizer>=2.2.0,<3",
      "spacy>=3.4.4,<3.7",
      "pydantic>=1.10.2,<2",
      "thinc<8.2",
      "typer>=0.4,<0.5",
      "cryptography<46"
    ],
    "ensure_pg_config": true,
    "ensure_mysql_config": true,
    "ensure_patchelf": true,
    "ensure_linux_native_build_tools": true,
    "pg_config_bin_path": "",
    "ensure_macos_build_flags": true,
    "macos_formula_candidates": [
      "libpq",
      "openssl@3",
      "openssl@1.1",
      "icu4c@78",
      "icu4c"
    ],
    "piicatcher_ignore_requires_python_on_failure": true,
    "piicatcher_install_spec": "git+https://github.com/tokern/piicatcher.git",
    "pip_constraints": {
      "pip": "<26",
      "setuptools": "<81",
      "wheel": ""
    },
    "download_spacy_model": true,
    "spacy_model": "en_core_web_lg",
    "spacy_model_version": "",
    "spacy_model_strict": false
  },
  "database_test_data": {
    "enabled": false,
    "script": "test_data/database/mysql/setup_mysql_sample.sh"
  },
  "packaging": {
    "enabled": true,
    "remove_incompatible_packages": true,
    "incompatible_packages": [
      "pathlib"
    ],
    "build_script": "build_executable.py",
    "name": "dpdp-pii-scanner",
    "command_name": "dpdp-scan",
    "onefile": false,
    "zip": true,
    "model_package": "en_core_web_lg",
    "allow_missing_model": false,
    "distpath": "dist",
    "workpath": "build/pyinstaller",
    "specpath": "build/pyinstaller"
  },
  "runtime_smoke_test": {
    "enabled": false,
    "config_file": "config/scanner/scanner_config.json",
    "output_file": "output/output.json"
  }
}
